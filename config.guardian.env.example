# Overrides guardian — systemd carrega por último (som só no Cozmo).
ECO_CHANCE=0
STT_PAUSE_DURING_TTS=1

NOTIF_PC_BEEP=0
NOTIF_PC_BEEP_VOLUME=65536
NOTIF_PC_AUDIO=0

# Limpeza automática de logs (guardian chama scripts/limpar-logs.sh)
GUARDIAN_LOG_TRIM_S=86400
COZMO_LOG_KEEP_LINES=12000
# Reinicia processo ainda ativo se o loop principal não atualizar a saúde.
GUARDIAN_HEALTH_STALE_S=240
GUARDIAN_BOOT_GRACE_S=180
